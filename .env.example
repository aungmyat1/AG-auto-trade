# AG Auto Trade — environment variables
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real keys.
#
# LOCKED constants (gate thresholds, risk limits) live in ag/config.py and
# are NEVER overridden by env vars. Do not add RISK_PER_TRADE_PCT etc. here.

# ── Phase B: Databento data layer (required for gate race) ──────────────────
DATABENTO_API_KEY=your_databento_api_key_here

# ── Telegram alerts (ag/monitoring/) ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── Phase 3: Interactive Brokers execution (NOT needed until ROBUST verdict) ─
# IB_HOST=127.0.0.1
# IB_PORT=7497
# IB_CLIENT_ID=1
